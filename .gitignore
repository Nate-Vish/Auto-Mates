# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings (user-specific)
.claude/settings.local.json

# Memory content (personal to each user)
**/Memory_Logs/Sessions/*.md
!**/Memory_Logs/Sessions/Session.md
**/Memory_Logs/Notes/*.md
!**/Memory_Logs/Notes/Note.md
**/Memory_Logs/Archive/*.md
!**/Memory_Logs/Archive/README.md

# Research library (user-specific)
Library/Sources/**
!Library/Sources/.gitkeep

# Environment files
.env
.env.*

# Secrets & credentials
*.pem
*.key
*.crt
*.p12
credentials.json
*-credentials.json
*_credentials.json
service-account*.json

# Dependencies & build artifacts
node_modules/
__pycache__/
*.pyc
*.log
